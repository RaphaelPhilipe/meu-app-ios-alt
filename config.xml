<?xml version="1.0" encoding="UTF-8"?>
<widget id="com.sigevalt.mobile" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>SIGEV Mobile</name>
    <description>Aplicativo iOS Cordova com interface mobile local integrada ao backend PHP por API JSON.</description>
    <author email="suporte@sigevalt.com" href="https://sigevalt.com">Equipe SIGEV</author>

    <content src="index.html" />
    <access origin="https://sigevalt.com" />
    <access origin="https://www.sigevalt.com" />
    <allow-navigation href="app://localhost/*" />
    <allow-navigation href="https://sigevalt.com/*" />
    <allow-navigation href="https://www.sigevalt.com/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="tel:*" />

    <platform name="ios">
        <preference name="deployment-target" value="12.0" />
        <preference name="scheme" value="app" />
        <preference name="hostname" value="localhost" />
        <preference name="WKWebViewOnly" value="true" />
        <preference name="SwiftVersion" value="5.0" />
        <preference name="AllowInlineMediaPlayback" value="true" />
        <preference name="KeyboardDisplayRequiresUserAction" value="false" />
        <preference name="DisallowOverscroll" value="true" />
        <preference name="ScrollEnabled" value="true" />
        <preference name="BackupWebStorage" value="local" />
        <preference name="StatusBarOverlaysWebView" value="false" />
        <preference name="StatusBarStyle" value="default" />

        <edit-config file="*-Info.plist" mode="merge" target="NSAppTransportSecurity">
            <dict>
                <key>NSAllowsArbitraryLoads</key>
                <false />
            </dict>
        </edit-config>
        <edit-config file="*-Info.plist" mode="merge" target="UISupportedInterfaceOrientations">
            <array>
                <string>UIInterfaceOrientationPortrait</string>
            </array>
        </edit-config>
        <config-file parent="UIViewControllerBasedStatusBarAppearance" target="*-Info.plist">
            <true />
        </config-file>
        <config-file parent="ITSAppUsesNonExemptEncryption" target="*-Info.plist">
            <false />
        </config-file>
        <config-file parent="NSCameraUsageDescription" target="*-Info.plist">
            <string>Preencha apenas se o app passar a usar camera para anexos ou comprovantes.</string>
        </config-file>
        <config-file parent="NSPhotoLibraryUsageDescription" target="*-Info.plist">
            <string>Preencha apenas se o app passar a anexar imagens da biblioteca do usuario.</string>
        </config-file>
        <config-file parent="NSLocationWhenInUseUsageDescription" target="*-Info.plist">
            <string>Preencha apenas se o app passar a registrar localizacao em visitas presenciais.</string>
        </config-file>
    </platform>

    <plugin name="cordova-plugin-device" spec="^3.0.0" />
    <plugin name="cordova-plugin-inappbrowser" spec="^6.0.0" />
    <plugin name="cordova-plugin-network-information" spec="^3.0.0" />
    <plugin name="cordova-plugin-splashscreen" spec="^6.0.2" />
    <plugin name="cordova-plugin-statusbar" spec="^4.0.0" />
    <plugin name="cordova-plugin-whitelist" spec="^1.3.5" />
    <plugin name="cordova-plugin-ionic-keyboard" spec="^2.2.0" />
</widget>
